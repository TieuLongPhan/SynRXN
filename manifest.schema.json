{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synrxn.org/schema/manifest-1.0.json",
  "title": "SynRXN release manifest",
  "type": "object",
  "required": ["schema_version", "generated_at", "dataset", "provenance", "project"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "dataset": {
      "type": "object",
      "required": ["title", "version", "description", "doi", "authors", "files", "summary"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "doi": {"type": "string", "pattern": "^10\\."},
        "authors": {"type": "array", "minItems": 1},
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["key", "size", "sha256"],
            "properties": {
              "key": {"type": "string", "minLength": 1, "pattern": "^[^/]"},
              "size": {"type": "integer", "minimum": 0},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "rows": {"type": "integer", "minimum": 0},
              "columns": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
              "format": {"type": "string"},
              "mime": {"type": "string"},
              "description": {"type": "string"},
              "license": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "summary": {
          "type": "object",
          "required": ["file_count", "total_bytes", "by_dir"],
          "properties": {
            "file_count": {"type": "integer", "minimum": 1},
            "total_bytes": {"type": "integer", "minimum": 0},
            "by_dir": {"type": "object"}
          }
        }
      },
      "additionalProperties": true
    },
    "provenance": {"type": "object"},
    "project": {"type": "object"},
    "code": {"type": "object"}
  },
  "additionalProperties": false
}
